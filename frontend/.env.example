# Copy this to .env.local (Next.js convention) and fill in real values.
# .env.local is gitignored.

# Backend URL the frontend calls. Defaults to 127.0.0.1:8000 in lib/api.ts.
# In production: NEXT_PUBLIC_API_URL=https://sharper-production.up.railway.app
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Supabase (auth + history). Get from supabase.com -> Project -> Settings -> API.
# The anon key is safe in the browser. NEVER paste the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Sentry (frontend project). Get from sentry.io ->
# Settings -> Projects -> [your Next.js project] -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=https://...@o000000.ingest.sentry.io/0000000
