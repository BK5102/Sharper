# Copy this to .env.local (Next.js convention) and fill in real values.
# .env.local is gitignored.

# Backend URL the frontend calls. Defaults to 127.0.0.1:8000 in lib/api.ts.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional bearer token sent as `Authorization: Bearer <token>` on every
# /api/lint call. Must match the backend's SHARPER_API_TOKEN. Note: this gets
# baked into the JS bundle and is publicly visible -- it is a stopgap for
# pre-Clerk deployments, not a real per-user secret. When Clerk lands, remove
# this and use the Clerk-issued JWT instead.
NEXT_PUBLIC_SHARPER_API_TOKEN=

# Clerk (Phase 3 step 8). Get from clerk.com -> your app -> API Keys.
# The publishable key is safe in the browser. NEVER paste the secret key here.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase (Phase 3 step 9 -- read-side from frontend). Get from supabase.com
# -> Project -> Settings -> API. The anon key is safe in the browser. NEVER
# paste the service_role key here -- that goes in backend/.env only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Sentry (Phase 3 step 11 -- frontend project). Get from sentry.io ->
# Settings -> Projects -> [your Next.js project] -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=https://...@o000000.ingest.sentry.io/0000000
