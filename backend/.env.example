ANTHROPIC_API_KEY=sk-ant-...
SHARPER_MODEL=claude-sonnet-4-6

# Static bearer token gating POST /api/lint. Set this in any environment that
# is publicly reachable -- the api.run() entrypoint refuses to bind to non-
# loopback hosts when this is unset. Local dev on 127.0.0.1 can leave it empty
# (requests pass through). Generate a token with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# This is a stopgap until Clerk auth lands; the dependency signature stays the
# same so swapping in JWT verification is a single-file change.
SHARPER_API_TOKEN=

# Only needed if you run scripts/fetch_metaculus.py - get one at
# metaculus.com -> profile -> API token.
METACULUS_API_TOKEN=

# Clerk (Phase 3 step 3). Get from clerk.com -> your app -> API Keys.
# Backend only needs the secret key (used to verify JWTs from the frontend).
# When set, /api/lint accepts Clerk session JWTs as Authorization: Bearer.
# When both CLERK_SECRET_KEY and SHARPER_API_TOKEN are set, Clerk is tried
# first; static-bearer is the fallback for service-to-service calls.
CLERK_SECRET_KEY=sk_test_...

# Comma-separated list of origins permitted to issue Clerk session tokens for
# our backend (i.e., the frontend Vercel URL + localhost dev origin). Verified
# against the JWT's `azp` claim. Leave empty in pure dev to skip the check.
# Example: CLERK_AUTHORIZED_PARTIES=https://sharper.vercel.app,http://localhost:3000
CLERK_AUTHORIZED_PARTIES=

# Upstash Redis (Phase 3 step 2 + 4). Get from upstash.com -> your Redis DB
# -> REST API section. Token is server-side only -- never expose to frontend.
# Quotas (hardcoded in sharper/ratelimit.py for now): 10 req/hr anonymous,
# 60 req/hr authenticated, fixed-window keyed by IP or Clerk user_id.
# When either var is unset, rate limiting is a silent no-op (dev mode).
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Supabase (Phase 3 step 5). Get from supabase.com -> Project Settings -> API.
# service_role key is server-side only -- NEVER expose to frontend or chat.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sentry (Phase 3 step 11 -- backend project). Get from sentry.io ->
# Settings -> Projects -> [your Python/FastAPI project] -> Client Keys (DSN).
SENTRY_DSN=https://...@o000000.ingest.sentry.io/0000000
